rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.displayName is string && data.displayName.size() <= 100
          && data.points is int && data.points >= 0
          && data.level is int && data.level >= 1
          && data.streak is int && data.streak >= 0;
      }

      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.points >= 0; // Public leaderboard access
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) 
        && isValidUser(request.resource.data)
        // Ensure UID is immutable
        && request.resource.data.uid == resource.data.uid;
    }

    // --- Decks & Cards ---
    match /decks/{deckId} {
      function isValidDeck(data) {
        return data.title is string && data.title.size() <= 100
          && data.icon is string && data.icon.size() <= 10
          && data.color is string && data.color.size() <= 20
          && (data.ownerId == null || data.ownerId == request.auth.uid);
      }

      allow read: if isSignedIn() && (
        resource.data.get('ownerId', null) == null || 
        resource.data.ownerId == request.auth.uid
      );
      allow create: if isSignedIn() && isValidDeck(request.resource.data) && request.resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && isValidDeck(request.resource.data);
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      match /cards/{cardId} {
        function getDeckOwner() {
          return get(/databases/$(database)/documents/decks/$(deckId)).data.ownerId;
        }

        allow read: if isSignedIn() && (getDeckOwner() == null || getDeckOwner() == request.auth.uid);
        allow write: if isSignedIn() && getDeckOwner() == request.auth.uid;
      }
    }

    // --- User Progress ---
    // Specifically matching subcollection structure
    match /userProgress/{userId}/cards/{cardId} {
      function isValidProgress(data) {
        return data.userId == request.auth.uid
          && data.cardId == cardId
          && data.interval is int && data.interval >= 0
          && data.repetitions is int && data.repetitions >= 0
          && data.easeFactor is number && data.easeFactor >= 1.3
          && data.nextReview is string;
      }

      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidProgress(request.resource.data);
    }
  }
}
